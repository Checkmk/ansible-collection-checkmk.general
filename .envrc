# -*- mode: sh -*-

layout_python() {
    # Using $PWD ensures we are working with an absolute path from the start,
    # preventing path-resolution mismatches in uv.
    local VIRTUAL_ENV="$PWD/.venv"

    if [[ ! -d "$VIRTUAL_ENV" ]]; then
        log_status "No virtual environment exists. Creating it."
        uv venv "$VIRTUAL_ENV"
        uv sync
    fi

    # Activate the virtual environment
    # (The activate script natively exports VIRTUAL_ENV="$venv_path")
    . "$VIRTUAL_ENV/bin/activate"

    # Tell uv to explicitly target this activated environment
    export UV_PROJECT_ENVIRONMENT="$VIRTUAL_ENV"
}

layout python
